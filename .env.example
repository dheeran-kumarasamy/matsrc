# Neon PostgreSQL
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/matsrc?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.neon.tech/matsrc?sslmode=require"

# Auth
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Facebook OAuth
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# Redis (Upstash)
REDIS_URL="redis://default:xxx@xxx.upstash.io:6379"

# AWS S3 (KYC docs, MTCs, UTR uploads)
AWS_REGION="ap-south-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET="matsrc-docs"

# AWS SES (email)
SES_FROM_EMAIL="noreply@matsrc.in"

# Razorpay
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# MSG91 (OTP / SMS)
MSG91_AUTH_KEY=""
MSG91_SENDER_ID=""
MSG91_TEMPLATE_ID=""

# Firebase FCM (push notifications)
FCM_SERVER_KEY=""

# Gupshup (WhatsApp Business API) — legacy/unused, kept for reference
GUPSHUP_API_KEY=""
GUPSHUP_APP_NAME=""
GUPSHUP_SOURCE_NUMBER=""

# WhatsApp Cloud API (Meta) — Supplier bot
# WHATSAPP_ADAPTER=mock (default, logs sends — safe for dev/test) | meta (real Graph API sends) | twilio (Twilio WhatsApp sends)
WHATSAPP_ADAPTER="mock"
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_BUSINESS_ACCOUNT_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_APP_SECRET=""
WHATSAPP_WEBHOOK_VERIFY_TOKEN=""
WHATSAPP_REENGAGEMENT_TEMPLATE="supplier_reengagement_nudge"

# Supplier bot via Twilio (WHATSAPP_ADAPTER=twilio) — apps/api/src/whatsapp/adapters/twilio-supplier-send.adapter.ts
# Reuses account-level TWILIO_ACCOUNT_SID / TWILIO_AUTH_TOKEN (shared with the separate
# whatsapp-alerts feature below), but uses its OWN sender number/Messaging Service SID
# and its own Content Template SIDs, so the two features can use different Twilio
# senders/webhooks even under the same Twilio account.
# Inbound webhook (configure in Twilio Console -> Messaging -> WhatsApp Sender ->
# "A MESSAGE COMES IN"): https://<your-domain>/api/whatsapp/twilio-webhook/messages
# Status callback webhook: https://<your-domain>/api/whatsapp/twilio-webhook/status
TWILIO_SUPPLIER_WHATSAPP_NUMBER=""
TWILIO_SUPPLIER_MESSAGING_SERVICE_SID=""
# Content Template SIDs for the two templates the bot sends (see META_SETUP.md §5) — only
# needed in Twilio production (approved templates); Twilio Sandbox has no custom
# templates, so the adapter falls back to a free-form text message when unset.
TWILIO_CONTENT_SID_SUPPLIER_OTP_VERIFICATION=""
TWILIO_CONTENT_SID_SUPPLIER_REENGAGEMENT=""
# Set to "true" to enforce X-Twilio-Signature validation on inbound webhook requests
# (requires TWILIO_WEBHOOK_PUBLIC_URL below). Left "false"/unset for local/dev/mock use.
TWILIO_WEBHOOK_VALIDATE_SIGNATURE="false"
# The exact public URL Twilio is configured to call for the inbound message webhook
# (e.g. https://xxxx.ngrok-free.app/api/whatsapp/twilio-webhook/messages) — required only
# when TWILIO_WEBHOOK_VALIDATE_SIGNATURE=true.
TWILIO_WEBHOOK_PUBLIC_URL=""

# WhatsApp Business Alerts (Twilio) — watchlist price hits, order-status updates,
# RFQ quote-received notices. Additive/non-blocking channel alongside existing
# email/SMS/push/in-app notifications; gated by WHATSAPP_ENABLED + per-user opt-in.
# Interim provider — see apps/api/src/notifications/whatsapp-alerts/NOTIFICATIONS.md
# for how to swap to a future Meta Cloud API provider without touching call sites.
WHATSAPP_ENABLED="false"
WHATSAPP_PROVIDER="twilio"
# sandbox = Twilio's shared WhatsApp Sandbox number, join-code opt-in, free-form-only
#   messaging (no custom templates) — safe for local/dev testing.
# production = a registered WhatsApp sender + approved Content Templates required.
# Validated at app startup (fails loudly, not lazily at send time) — see
# apps/api/src/notifications/whatsapp-alerts/whatsapp-alert-config.service.ts
WHATSAPP_MODE="sandbox"
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
# Either set a WhatsApp-enabled "from" number OR a Messaging Service SID (not both required)
# Sandbox mode expects this to be the well-known Twilio Sandbox number (+14155238886).
TWILIO_WHATSAPP_NUMBER=""
TWILIO_MESSAGING_SERVICE_SID=""
# Explicit override: set to "true" only if intentionally running WHATSAPP_MODE=sandbox
# against a non-standard (not +14155238886) number. Without this, sandbox mode + an
# unrecognized number fails startup, to avoid accidentally treating a real/production
# number as a sandbox number.
TWILIO_SANDBOX_NUMBER_OVERRIDE="false"

# Twilio Content Template SIDs — one per logical alert templateKey (see
# WhatsAppAlertConfigService.getTwilioContentSid for the templateKey -> SID mapping)
TWILIO_CONTENT_SID_WATCHLIST_PRICE_HIT=""
TWILIO_CONTENT_SID_ORDER_STATUS_UPDATE=""
TWILIO_CONTENT_SID_RFQ_QUOTE_RECEIVED=""
# Shared secret used to validate Twilio delivery-status webhook callbacks
# (POST /whatsapp-alerts/status). Leave blank in local/dev to skip verification.
TWILIO_STATUS_CALLBACK_AUTH_TOKEN=""

# WhatsApp Lifecycle Notifications — outbound order/enquiry-lifecycle Utility templates
# for Builders and Suppliers. Reuses the existing WHATSAPP_ADAPTER send provider,
# WhatsAppSessionService-style idempotency (durable, AuditLog-backed) and
# WhatsAppAuditHelper (channel: "whatsapp"). See apps/api/src/whatsapp/lifecycle/.
WHATSAPP_LIFECYCLE_ENABLED="true"
# Hours an enquiry can sit in PLACED before the "pending update" nudge fires.
WHATSAPP_ENQUIRY_NUDGE_THRESHOLD_HOURS="4"
# How often (ms) the enquiry-nudge sweep runs.
WHATSAPP_ENQUIRY_NUDGE_SWEEP_INTERVAL_MS="900000"
# How often (ms) the daily supplier-digest job checks whether it's time to fire.
WHATSAPP_DAILY_DIGEST_SWEEP_INTERVAL_MS="1800000"
# Hour of day (0-23, server local time) the daily supplier digest should fire.
WHATSAPP_DAILY_DIGEST_HOUR="9"
# Meta template language code used for all lifecycle template sends.
WHATSAPP_LIFECYCLE_LANGUAGE="en"
# Set to "true" to disable the two background sweep schedulers (enquiry-nudge +
# daily-digest) — e.g. for tests or when running multiple API instances where only
# one should sweep. Leave unset/"false" to run normally.
WHATSAPP_LIFECYCLE_SWEEP_DISABLED="false"
# Meta template names — each overridable so Meta approvals can rename freely without
# code changes. Defaults match the key name (see WhatsAppLifecycleConfigService).
WHATSAPP_TEMPLATE_BUILDER_ORDER_PLACED="builder_order_placed"
WHATSAPP_TEMPLATE_BUILDER_ENQUIRY_PENDING_UPDATE="builder_enquiry_pending_update"
WHATSAPP_TEMPLATE_BUILDER_ORDER_ACCEPTED="builder_order_accepted"
WHATSAPP_TEMPLATE_BUILDER_PO_ISSUED="builder_po_issued"
WHATSAPP_TEMPLATE_BUILDER_PAYMENT_LINK_CASH="builder_payment_link"
WHATSAPP_TEMPLATE_BUILDER_PAYMENT_LINK_BNPL_CREDIT="builder_payment_link"
WHATSAPP_TEMPLATE_BUILDER_DELIVERY_ETA="builder_delivery_eta"
WHATSAPP_TEMPLATE_BUILDER_ORDER_DISPATCHED="builder_order_dispatched"
WHATSAPP_TEMPLATE_BUILDER_ORDER_OUT_FOR_DELIVERY="builder_order_out_for_delivery"
WHATSAPP_TEMPLATE_BUILDER_ORDER_DELIVERED="builder_order_delivered"
WHATSAPP_TEMPLATE_SUPPLIER_NEW_ENQUIRY_NOTIFICATION="supplier_new_enquiry_notification"
WHATSAPP_TEMPLATE_SUPPLIER_PENDING_ENQUIRIES_REMINDER="supplier_pending_enquiries_reminder"
WHATSAPP_TEMPLATE_SUPPLIER_PENDING_DELIVERIES_REMINDER="supplier_pending_deliveries_reminder"
WHATSAPP_TEMPLATE_SUPPLIER_INVOICE_GENERATED="supplier_invoice_generated"


# GST e-Invoice (Masters India / ClearTax)

GST_IRP_API_KEY=""
GST_IRP_BASE_URL=""

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# NestJS API URL (used by Next.js apps)
NEXT_PUBLIC_API_URL="http://localhost:4000"
API_PORT=4000
