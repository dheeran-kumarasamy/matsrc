# Neon PostgreSQL
DATABASE_URL="postgresql://user:password@ep-xxx.neon.tech/matsrc?sslmode=require"
DIRECT_URL="postgresql://user:password@ep-xxx.neon.tech/matsrc?sslmode=require"

# Auth
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Facebook OAuth
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# Redis (Upstash)
REDIS_URL="redis://default:xxx@xxx.upstash.io:6379"

# AWS S3 (KYC docs, MTCs, UTR uploads)
AWS_REGION="ap-south-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_S3_BUCKET="matsrc-docs"

# AWS SES (email)
SES_FROM_EMAIL="noreply@matsrc.in"

# Razorpay
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
RAZORPAY_WEBHOOK_SECRET=""

# MSG91 (OTP / SMS)
MSG91_AUTH_KEY=""
MSG91_SENDER_ID=""
MSG91_TEMPLATE_ID=""

# Firebase FCM (push notifications)
FCM_SERVER_KEY=""

# Gupshup (WhatsApp Business API) — legacy/unused, kept for reference
GUPSHUP_API_KEY=""
GUPSHUP_APP_NAME=""
GUPSHUP_SOURCE_NUMBER=""

# WhatsApp Cloud API (Meta) — Supplier bot
# WHATSAPP_ADAPTER=mock (default, logs sends — safe for dev/test) | meta (real Graph API sends)
WHATSAPP_ADAPTER="mock"
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_BUSINESS_ACCOUNT_ID=""
WHATSAPP_ACCESS_TOKEN=""
WHATSAPP_APP_SECRET=""
WHATSAPP_WEBHOOK_VERIFY_TOKEN=""
WHATSAPP_REENGAGEMENT_TEMPLATE="supplier_reengagement_nudge"


# GST e-Invoice (Masters India / ClearTax)
GST_IRP_API_KEY=""
GST_IRP_BASE_URL=""

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# NestJS API URL (used by Next.js apps)
NEXT_PUBLIC_API_URL="http://localhost:4000"
API_PORT=4000
