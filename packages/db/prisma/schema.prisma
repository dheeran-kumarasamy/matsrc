// packages/db/prisma/schema.prisma
// BuildMart — Prisma schema (Neon PostgreSQL)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// M01 Authentication & User Management
// ─────────────────────────────────────────────

enum Role {
  BUILDER
  SUPPLIER
  ADMIN
  SUPER_ADMIN
}

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id            String      @id @default(cuid())
  email         String?     @unique
  phone         String?     @unique
  name          String?
  role          Role
  kycStatus     KycStatus   @default(PENDING)
  mfaEnabled    Boolean     @default(false)
  mfaSecret     String?
  whatsappNumber String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  // Relations
  kycDocuments  KycDocument[]
  orders        Order[]
  cart          CartItem[]
  watchlist     Watchlist[]
  disputes      Dispute[]
  supplierRatingsGiven SupplierRating[] @relation("BuilderSupplierRatings")
  purchaseOrders PurchaseOrder[] @relation("BuilderPurchaseOrders")
  notifications Notification[]
  aggregationParticipations AggregationParticipant[]

  notificationPreference NotificationPreference?
  creditProfile CreditProfile?
  supplierProfile SupplierProfile?
  adminCredential AdminCredential?
  adminMenuPermissions AdminMenuPermission[]

  @@index([email])
  @@index([phone])
}

model AdminCredential {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AdminMenuPermission {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  menu      String
  createdAt DateTime @default(now())

  @@unique([userId, menu])
  @@index([userId])
}

model KycDocument {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  type       String    // GST_CERT | AADHAAR | TRADE_LICENCE | BIS_CERT
  fileUrl    String
  verified   Boolean   @default(false)
  createdAt  DateTime  @default(now())

  @@index([userId])
}

// ─────────────────────────────────────────────
// M02 Product Catalogue + M07 Supplier Portal
// ─────────────────────────────────────────────

model SupplierProfile {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id])
  companyName     String
  bisLicenceNo    String?
  bisVerified     Boolean   @default(false)
  verifiedBadge   Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  products        Product[]
  orderItems      OrderItem[]
  quotes          Quote[]
  supplierQuotes  SupplierQuote[]
  ratings         SupplierRating[]
  selectedOrders  Order[]         @relation("SelectedSupplierOrders")
  mtcCertificates MtcCertificate[]
  purchaseOrders  PurchaseOrder[]
  aggregationPools AggregationPool[]
}

model Category {
  id       String    @id @default(cuid())
  name     String    @unique
  slug     String    @unique
  isActive Boolean   @default(true)
  products Product[]
  canonicalProducts CanonicalProduct[]
}

// ─────────────────────────────────────────────
// Standardized catalog master data (admin-configured)
// Brand / Grade / Unit are enumerated, admin-managed lists —
// supplier listing creation and builder search/filter must select
// from these lists rather than free text. Mirrors the existing
// Category model shape for consistency.
// ─────────────────────────────────────────────

model Brand {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
  canonicalProducts CanonicalProduct[]
}

model Grade {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
  canonicalProducts CanonicalProduct[]
}

model Unit {
  id        String    @id @default(cuid())
  name      String    @unique // display label, e.g. "Metric Ton"
  code      String    @unique // short code, e.g. "MT"
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
  canonicalProducts CanonicalProduct[]
}

// Canonical "same physical product across suppliers" grouping.
// A CanonicalProduct is derived deterministically from
// category + brand + grade + unit (all now FK-constrained master data)
// so matching is exact, not fuzzy.
model CanonicalProduct {
  id           String    @id @default(cuid())
  canonicalKey String    @unique
  categoryId   String
  category     Category  @relation(fields: [categoryId], references: [id])
  brandId      String?
  brand        Brand?    @relation(fields: [brandId], references: [id])
  gradeId      String?
  grade        Grade?    @relation(fields: [gradeId], references: [id])
  unitId       String?
  unit         Unit?     @relation(fields: [unitId], references: [id])
  title        String    // display name for the merged discovery card
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  products     Product[]

  @@index([categoryId])
}

model Product {
  id              String          @id @default(cuid())
  supplierId      String
  supplier        SupplierProfile @relation(fields: [supplierId], references: [id])
  categoryId      String
  category        Category        @relation(fields: [categoryId], references: [id])
  name            String
  slug            String          @unique
  brand           String?         // deprecated free-text value, retained for backfill/history only
  grade           String?         // deprecated free-text value, retained for backfill/history only
  brandId         String?
  brandRef        Brand?          @relation(fields: [brandId], references: [id])
  gradeId         String?
  gradeRef        Grade?          @relation(fields: [gradeId], references: [id])
  unitId          String?
  unitRef         Unit?           @relation(fields: [unitId], references: [id])
  isCode          String?
  bisStatus       String?         // CERTIFIED | PENDING | NA
  description     String?
  unit            String          // deprecated free-text value (MT | BAG | SQM | PCS), retained for backfill/history only
  basePrice       Decimal         @db.Decimal(12, 2)
  stock           Int             @default(0)
  maxServiceableQty Int?          
  images          String[]
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  // Order Aggregation ("Group & Save") — supplier-configured per listing, opt-in only.
  aggregationEnabled    Boolean  @default(false)
  aggregationPriceTiers Json?    // [{minQty, unitPrice}] — separate from PricingTier (non-aggregated bulk pricing)
  aggregationZoneRules  Json?    // reserved for future zone-grouping configuration
  aggregationWindowDays Int?     @default(7)

  // Cross-supplier canonical product grouping (additive; nullable until backfilled)
  canonicalProductId String?
  canonicalProduct   CanonicalProduct? @relation(fields: [canonicalProductId], references: [id])

  prices          PricePoint[]
  pricingTiers    PricingTier[]
  cartItems       CartItem[]
  orderItems      OrderItem[]
  interestEvents  ProductInterestEvent[]
  watchlist       Watchlist[]
  mtcCertificates MtcCertificate[]
  purchaseOrderLineItems PurchaseOrderLineItem[]
  aggregationPools AggregationPool[]

  @@index([supplierId])
  @@index([categoryId])
  @@index([slug])
  @@index([canonicalProductId])
  @@index([brandId])
  @@index([gradeId])
  @@index([unitId])
}


model MtcCertificate {
  id          String          @id @default(cuid())
  productId   String
  product     Product         @relation(fields: [productId], references: [id])
  supplierId  String
  supplier    SupplierProfile @relation(fields: [supplierId], references: [id])
  fileUrl     String
  batchNo     String?
  verified    Boolean         @default(false)
  createdAt   DateTime        @default(now())

  @@index([productId])
}

// ─────────────────────────────────────────────
// M03 Pricing & Market Intelligence
// ─────────────────────────────────────────────

model PricePoint {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  sourceCity  String   // EX-Raipur, EX-Vizag, etc.
  price       Decimal  @db.Decimal(12, 2)
  freight     Decimal  @db.Decimal(10, 2) @default(0)
  recordedAt  DateTime @default(now())

  @@index([productId])
  @@index([recordedAt])
}

model PricingTier {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  minQty      Int
  maxQty      Int
  tierPrice   Decimal  @db.Decimal(12, 2)
  createdAt   DateTime @default(now())

  @@index([productId])
  @@unique([productId, minQty, maxQty])
}

model Watchlist {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  productId      String
  product        Product  @relation(fields: [productId], references: [id])
  targetPrice    Decimal? @db.Decimal(12, 2)
  alertSent      Boolean  @default(false)
  createdAt      DateTime @default(now())

  @@unique([userId, productId])
  @@index([userId])
}

model Quote {
  id          String          @id @default(cuid())
  supplierId  String
  supplier    SupplierProfile @relation(fields: [supplierId], references: [id])
  rfqId       String?
  rfq         QuickRequest?   @relation(fields: [rfqId], references: [id])
  price       Decimal         @db.Decimal(12, 2)
  validUntil  DateTime?
  notes       String?
  createdAt   DateTime        @default(now())

  @@index([supplierId])
}

model SupplierQuote {
  id           String          @id @default(cuid())
  enquiryId    String
  enquiry      Order           @relation(fields: [enquiryId], references: [id])
  supplierId   String
  supplier     SupplierProfile @relation(fields: [supplierId], references: [id])
  lineItemId   String
  lineItem     OrderItem       @relation(fields: [lineItemId], references: [id])
  unitPrice    Decimal         @db.Decimal(12, 2)
  currency     String          @default("INR")
  leadTimeDays Int?
  createdAt    DateTime        @default(now())

  @@index([enquiryId])
  @@index([supplierId])
  @@index([lineItemId])
  @@index([enquiryId, lineItemId])
}

model QuickRequest {
  id          String   @id @default(cuid())
  userId      String
  materialName String
  quantity    String
  pincode     String
  notes       String?
  createdAt   DateTime @default(now())

  quotes      Quote[]
}

// ─────────────────────────────────────────────
// M04 Cart & Order Management
// ─────────────────────────────────────────────

model CartItem {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  productId String
  product   Product  @relation(fields: [productId], references: [id])
  quantity  Int
  updatedAt DateTime @updatedAt

  // Cross-supplier resolution snapshot (populated at add-to-cart time; re-resolved
  // at checkout). Nullable/additive so existing rows and single-supplier products
  // keep working unchanged.
  resolvedListingId   String?
  resolvedSupplierId  String?
  resolvedTierMinQty  Int?
  resolvedTierMaxQty  Int?
  resolvedUnitPrice   Decimal? @db.Decimal(12, 2)
  resolvedAt          DateTime?

  @@unique([userId, productId])
  @@index([userId])
}

enum OrderStatus {
  PLACED
  PROCESSING
  DISPATCHED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
}

enum PaymentMethod {
  UPI
  CARD
  NET_BANKING
  COD
  CREDIT
  BANK_TRANSFER
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model Order {
  id              String        @id @default(cuid())
  userId          String
  user            User          @relation(fields: [userId], references: [id])
  status          OrderStatus   @default(PLACED)
  paymentMethod   PaymentMethod
  paymentStatus   PaymentStatus @default(PENDING)
  paymentRef      String?
  utrProofUrl     String?
  gstInvoiceUrl   String?
  irn             String?
  totalAmount     Decimal       @db.Decimal(12, 2)
  deliveryDate    DateTime?
  // REQ-07: map-based geolocation capture, replacing the checkout pincode
  // field. Nullable so existing rows and any flow that doesn't collect a
  // location (e.g. the separate Group & Save checkout page, which still
  // uses its own pincode-based zoneKey) are unaffected.
  deliveryLat        Float?
  deliveryLng         Float?
  deliveryAddress     String?
  selectedSupplierId String?

  selectedSupplier   SupplierProfile? @relation("SelectedSupplierOrders", fields: [selectedSupplierId], references: [id])
  bestPriceTotal     Decimal?      @db.Decimal(12, 2)
  tentativeDeliveryDate DateTime?
  quoteSelectionCompletedAt DateTime?
  // WhatsApp lifecycle notifications: tracks whether the "enquiry pending update" nudge
  // (builder_enquiry_pending_update) has already been sent for this enquiry, so the
  // scheduled sweep in WhatsAppLifecycle never sends it more than once per enquiry.
  reminderSentAt  DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt


  // Order Aggregation ("Group & Save")
  aggregationPoolId      String?
  aggregationPool        AggregationPool? @relation(fields: [aggregationPoolId], references: [id])
  isAggregated           Boolean  @default(false)
  priceBeforeAggregation Decimal? @db.Decimal(12, 2)
  priceAfterAggregation  Decimal? @db.Decimal(12, 2)

  items           OrderItem[]
  tracking        OrderTracking[]
  dispute         Dispute?
  supplierQuotes  SupplierQuote[]
  supplierRating  SupplierRating?
  purchaseOrders  PurchaseOrder[]
  aggregationParticipant AggregationParticipant?

  @@index([userId])
  @@index([status])
  @@index([selectedSupplierId])
  @@index([aggregationPoolId])
}


model OrderItem {
  id          String          @id @default(cuid())
  orderId     String
  order       Order           @relation(fields: [orderId], references: [id])
  productId   String
  product     Product         @relation(fields: [productId], references: [id])
  supplierId  String
  supplier    SupplierProfile @relation(fields: [supplierId], references: [id])
  quantity    Int
  unitPrice   Decimal         @db.Decimal(12, 2)
  deliveryDate DateTime?
  supplierQuotes SupplierQuote[]

  // Cross-supplier resolution audit trail (additive). Captures which canonical
  // product/tier/listing this line item resolved to and when, so disputes/admin
  // can answer "why was this assigned to Supplier X".
  canonicalProductId  String?
  resolvedListingId   String?
  tierMinQty          Int?
  tierMaxQty          Int?
  priceAtResolution   Decimal?  @db.Decimal(12, 2)
  resolvedAt          DateTime?

  // REQ-06: the minimum price across the canonical product's cross-supplier
  // price range at the time the enquiry was submitted — this is the only
  // price figure surfaced to the supplier (the builder-facing UI continues
  // to show the full min–max range). Nullable so existing rows are
  // unaffected; falls back to unitPrice when absent (legacy orders).
  askPrice            Decimal?  @db.Decimal(12, 2)

  @@index([orderId])
  @@index([supplierId])
}


// ─────────────────────────────────────────────
// M06 Order Tracking
// ─────────────────────────────────────────────

model OrderTracking {
  id          String      @id @default(cuid())
  orderId     String
  order       Order       @relation(fields: [orderId], references: [id])
  status      OrderStatus
  gpsVehicleId String?
  latitude    Float?
  longitude   Float?
  note        String?
  recordedAt  DateTime    @default(now())

  @@index([orderId])
}

// ─────────────────────────────────────────────
// M08 Credit & Lending
// ─────────────────────────────────────────────

enum CreditStatus {
  NOT_APPLIED
  SCORING
  APPROVED
  REJECTED
  ACTIVE
}

model CreditProfile {
  id              String       @id @default(cuid())
  userId          String       @unique
  user            User         @relation(fields: [userId], references: [id])
  creditLimit     Decimal?     @db.Decimal(12, 2)
  usedLimit       Decimal      @db.Decimal(12, 2) @default(0)
  status          CreditStatus @default(NOT_APPLIED)
  kfsAcceptedAt   DateTime?
  nbfcRef         String?

  // REQ-09: Bank Guarantee registration, moved into BUILDER onboarding
  // (previously not modeled anywhere in the schema). Kept on CreditProfile
  // since it is conceptually another credit/lending product alongside
  // EMI/BNPL/Working Capital, reusing the same status lifecycle pattern.
  bankGuaranteeEnabled     Boolean       @default(false)
  bankGuaranteeStatus      CreditStatus  @default(NOT_APPLIED)
  bankGuaranteeAmount      Decimal?      @db.Decimal(12, 2)
  bankGuaranteeDocUrl      String?
  bankGuaranteeIssuerName  String?
  bankGuaranteeValidTill   DateTime?
  bankGuaranteeAcceptedAt  DateTime?

  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
}


// ─────────────────────────────────────────────
// M09 Notifications, Reviews & Admin
// ─────────────────────────────────────────────

enum NotificationChannel {
  PUSH
  SMS
  EMAIL
  WHATSAPP
  IN_APP
}

model NotificationPreference {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id])
  whatsappEnabled Boolean  @default(true)
  smsEnabled      Boolean  @default(true)
  emailEnabled    Boolean  @default(true)
  pushEnabled     Boolean  @default(true)
  inAppEnabled    Boolean  @default(true)
  // Explicit consent to receive outbound WhatsApp *business alert* messages
  // (watchlist price hits, order-status updates, RFQ quote-received notices)
  // via the Twilio/Meta WhatsApp alert provider. Deliberately separate from
  // `whatsappEnabled` above (which gates the pre-existing mock/basic WhatsApp
  // channel) — defaults to false so no user is ever messaged without
  // explicit opt-in.
  whatsappOptIn   Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}


enum NotificationTemplateType {
  ORDER_SUBMITTED
  ENQUIRY_SUBMITTED_TO_SUPPLIER
  ENQUIRY_BEST_PRICE_TO_BUILDER
  ORDER_ACCEPTED
  ORDER_DECLINED
  ORDER_DISPATCHED
  ORDER_OUT_FOR_DELIVERY
  ORDER_DELIVERED
  PAYMENT_UNLOCKED
  PAYMENT_REMINDER
  RFQ_QUOTE_SHARED
  DISPUTE_CREATED
  DISPUTE_RESOLVED
  KYC_APPROVED
  KYC_REJECTED
  WATCHLIST_ALERT
  AGGREGATION_OPT_IN_CONFIRMED
  AGGREGATION_TIER_IMPROVED
  AGGREGATION_WINDOW_CLOSING_SOON
  AGGREGATION_POOL_LOCKED
  AGGREGATION_OPT_OUT_CONFIRMED
}


model NotificationTemplate {
  id        String                   @id @default(cuid())
  type      NotificationTemplateType @unique
  channel   NotificationChannel
  title     String
  body      String
  variables String[]                 // JSON array of variable names
  language  String                   @default("en")
  version   Int                      @default(1)
  active    Boolean                  @default(true)
  createdAt DateTime                 @default(now())
  updatedAt DateTime                 @updatedAt

  @@unique([type, channel, language, version])
  @@index([type])
}

model Notification {
  id              String              @id @default(cuid())
  userId          String
  user            User                @relation(fields: [userId], references: [id])
  channel         NotificationChannel
  audience        String?
  title           String
  body            String
  read            Boolean             @default(false)
  externalId      String?             // Provider-assigned message ID
  idempotencyKey  String?
  status          String              @default("pending") // pending, sent, delivered, failed
  failureReason   String?
  retryCount      Int                 @default(0)
  maxRetries      Int                 @default(3)
  templateType    NotificationTemplateType?
  variables       String?             // JSON object of template variables
  sentAt          DateTime            @default(now())
  deliveredAt     DateTime?
  failedAt        DateTime?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  deliveryLogs    NotificationDeliveryLog[]

  @@index([userId])
  @@index([status])
  @@index([externalId])
  @@unique([idempotencyKey])
}

model NotificationDeliveryLog {
  id              String      @id @default(cuid())
  notificationId  String
  notification    Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  previousStatus  String?
  newStatus       String
  provider        String?     // whatsapp, sms, email, push
  errorCode       String?
  errorMessage    String?
  metadata        String?     // JSON blob for provider-specific details
  createdAt       DateTime    @default(now())

  @@index([notificationId])
  @@index([newStatus])
}

enum DisputeStatus {
  OPEN
  UNDER_REVIEW
  RESOLVED
  ESCALATED
}

model Dispute {
  id          String        @id @default(cuid())
  orderId     String        @unique
  order       Order         @relation(fields: [orderId], references: [id])
  userId      String
  user        User          @relation(fields: [userId], references: [id])
  issueType   String
  description String
  evidenceUrls String[]
  status      DisputeStatus @default(OPEN)
  resolution  String?
  rating      Int?          // 1-5
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  escalateAt  DateTime?

  @@index([userId])
  @@index([status])
}

model SupplierRating {
  id             String          @id @default(cuid())
  orderId         String          @unique
  order           Order           @relation(fields: [orderId], references: [id])
  supplierId      String
  supplier        SupplierProfile @relation(fields: [supplierId], references: [id])
  builderId       String
  builder         User            @relation("BuilderSupplierRatings", fields: [builderId], references: [id])
  deliveryRating  Int
  qualityRating   Int
  comment         String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([supplierId])
  @@index([builderId])
}

enum PurchaseOrderStatus {
  DRAFT
  ISSUED
  ACKNOWLEDGED
  FULFILLED
}

model PurchaseOrder {
  id             String              @id @default(cuid())
  poNumber       String              @unique
  builderId      String
  builder        User                @relation("BuilderPurchaseOrders", fields: [builderId], references: [id])
  supplierId     String
  supplier       SupplierProfile     @relation(fields: [supplierId], references: [id])
  orderId        String
  order          Order               @relation(fields: [orderId], references: [id])
  status         PurchaseOrderStatus @default(DRAFT)
  version        Int                 @default(1)
  notes          String?
  termsSnapshot  Json?
  approvedAt     DateTime?
  approvedBy     String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  lineItems      PurchaseOrderLineItem[]

  @@index([builderId])
  @@index([supplierId])
  @@index([orderId])
  @@index([status])
}

model PurchaseOrderLineItem {
  id                String        @id @default(cuid())
  purchaseOrderId   String
  purchaseOrder     PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  productId         String
  product           Product       @relation(fields: [productId], references: [id])
  quantity          Int
  unitPrice         Decimal       @db.Decimal(12, 2)
  tax               Decimal       @db.Decimal(12, 2) @default(0)
  deliveryDate      DateTime?
  fulfilledQuantity Int           @default(0)

  @@index([purchaseOrderId])
  @@index([productId])
}

enum ProductInterestEventType {
  VIEW
  CART_ADD
  ORDER_PLACED
}


model ProductInterestEvent {
  id         String                   @id @default(cuid())
  listingId  String
  listing    Product                  @relation(fields: [listingId], references: [id])
  sessionId  String
  eventType  ProductInterestEventType
  createdAt  DateTime                 @default(now())

  @@index([listingId, eventType, createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String
  entityType String
  entityId   String
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([entityType, entityId])
}

// ─────────────────────────────────────────────
// M10 Order Aggregation ("Group & Save")
// ─────────────────────────────────────────────

enum AggregationPoolStatus {
  OPEN
  LOCKED
  FULFILLING
  CLOSED
  CANCELLED
}

enum AggregationParticipantStatus {
  PENDING
  LOCKED_IN
  CONVERTED
  OPTED_OUT
}

model AggregationPool {
  id                  String                @id @default(cuid())
  supplierId          String
  supplier            SupplierProfile       @relation(fields: [supplierId], references: [id])
  productId           String
  product             Product               @relation(fields: [productId], references: [id])
  zoneKey             String                // pincode-based zone granularity (v1: exact pincode string)
  deliveryWindowStart DateTime
  deliveryWindowEnd   DateTime
  status              AggregationPoolStatus @default(OPEN)
  currentQuantity     Int                   @default(0)
  priceTiers          Json                  // [{minQty, unitPrice}] snapshot copied from Product at pool creation
  lockedUnitPrice     Decimal?              @db.Decimal(12, 2)
  windowCloseAt       DateTime
  lockedAt            DateTime?
  createdAt           DateTime              @default(now())
  updatedAt           DateTime              @updatedAt

  participants        AggregationParticipant[]
  orders              Order[]

  @@index([supplierId])
  @@index([productId, zoneKey, status])
  @@index([status])
  @@index([windowCloseAt])
}

model AggregationParticipant {
  id         String                        @id @default(cuid())
  poolId     String
  pool       AggregationPool               @relation(fields: [poolId], references: [id])
  builderId  String
  builder    User                          @relation(fields: [builderId], references: [id])
  orderId    String?                       @unique
  order      Order?                        @relation(fields: [orderId], references: [id])
  quantity   Int
  status     AggregationParticipantStatus  @default(PENDING)
  optedInAt  DateTime                      @default(now())
  optedOutAt DateTime?

  @@index([poolId])
  @@index([builderId])
  @@index([poolId, status])
}
